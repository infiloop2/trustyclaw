{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "Ec2Discovery",
      "Effect": "Allow",
      "Action": [
        "ec2:DescribeInstances",
        "ec2:DescribeVpcs",
        "ec2:DescribeSubnets",
        "ec2:DescribeRouteTables",
        "ec2:DescribeSecurityGroups",
        "ec2:DescribeVolumes",
        "ec2:DescribeInstanceAttribute"
      ],
      "Resource": "*"
    },
    {
      "Sid": "CreateTaggedTrustyClawResources",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateVolume",
        "ec2:CreateSecurityGroup"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/trustyclaw-host": "true",
          "aws:RequestTag/trustyclaw-host-agent-name": "trustyclaw-stage"
        }
      }
    },
    {
      "Sid": "UseEc2CreateDependencies",
      "Effect": "Allow",
      "Action": [
        "ec2:RunInstances",
        "ec2:CreateSecurityGroup"
      ],
      "Resource": [
        "arn:aws:ec2:*::image/*",
        "arn:aws:ec2:*:*:subnet/*",
        "arn:aws:ec2:*:*:network-interface/*",
        "arn:aws:ec2:*:*:vpc/*"
      ]
    },
    {
      "Sid": "RunInstancesWithTrustyClawSecurityGroups",
      "Effect": "Allow",
      "Action": "ec2:RunInstances",
      "Resource": "arn:aws:ec2:*:*:security-group/*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/trustyclaw-host": "true",
          "aws:ResourceTag/trustyclaw-host-agent-name": "trustyclaw-stage"
        }
      }
    },
    {
      "Sid": "TagOnlyDuringTrustyClawResourceCreation",
      "Effect": "Allow",
      "Action": "ec2:CreateTags",
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:RequestTag/trustyclaw-host": "true",
          "aws:RequestTag/trustyclaw-host-agent-name": "trustyclaw-stage",
          "ec2:CreateAction": [
            "RunInstances",
            "CreateVolume",
            "CreateSecurityGroup"
          ]
        }
      }
    },
    {
      "Sid": "ManageOnlyTrustyClawResources",
      "Effect": "Allow",
      "Action": [
        "ec2:GetConsoleOutput",
        "ec2:AttachVolume",
        "ec2:AuthorizeSecurityGroupIngress",
        "ec2:AuthorizeSecurityGroupEgress",
        "ec2:StartInstances",
        "ec2:TerminateInstances",
        "ec2:StopInstances",
        "ec2:DeleteSecurityGroup",
        "ec2:DeleteVolume",
        "ec2:RevokeSecurityGroupIngress",
        "ec2:RevokeSecurityGroupEgress"
      ],
      "Resource": "*",
      "Condition": {
        "StringEquals": {
          "aws:ResourceTag/trustyclaw-host": "true",
          "aws:ResourceTag/trustyclaw-host-agent-name": "trustyclaw-stage"
        }
      }
    },
    {
      "Sid": "UbuntuAmiLookup",
      "Effect": "Allow",
      "Action": "ssm:GetParameter",
      "Resource": "arn:aws:ssm:*::parameter/aws/service/canonical/*"
    }
  ]
}
